# -*- coding: utf-8 -*-
# .env.example  -  环境变量配置模板
#
# 使用方法：
#   1. 复制此文件为 .env
#   2. Linux/macOS: source .env   或直接在 shell 中 export
#   3. Windows PowerShell: $env:HEALTH_DB_PASSWORD="你的密码"
#
# 如果不设置这些变量，程序启动时会报错并退出（防止生产环境意外无密码启动）

# MySQL 数据库配置
HEALTH_DB_USER=root
HEALTH_DB_PASSWORD=你的MySQL密码          # ← 改成你安装 MySQL 时设置的密码
HEALTH_DB_HOST=localhost
HEALTH_DB_PORT=3306
HEALTH_DB_NAME=health_db

# Session 加密密钥（随机字符串，可用下方命令生成）
HEALTH_SECRET_KEY=在此粘贴你的随机密钥     # ← 改成随机字符串
